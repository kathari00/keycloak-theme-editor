{
  "name": "keycloak-theme-editor",
  "type": "module",
  "version": "0.3.4",
  "description": "Visual theme editor for Keycloak login pages. Style, preview, and export Keycloak themes without cloning or forking.",
  "license": "Apache-2.0",
  "keywords": [
    "keycloak",
    "theme",
    "editor",
    "login",
    "freemarker",
    "css",
    "visual-editor"
  ],
  "exports": {
    ".": {
      "types": "./bin/kc-mocks.d.ts",
      "default": "./bin/kc-mocks.js"
    }
  },
  "bin": {
    "keycloak-theme-editor": "./bin/cli.js"
  },
  "files": [
    "bin/cli.js",
    "bin/kc-mocks.d.ts",
    "bin/kc-mocks.js",
    "dist/",
    "tools/preview-renderer/lib/",
    "tools/preview-renderer/preview-renderer.jar"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:jar": "mvn -f tools/preview-renderer/pom.xml clean package -q",
    "build:cli": "tsup --config bin/tsup.config.ts",
    "prepublishOnly": "npm run build && npm run build:jar && npm run build:cli",
    "lint": "eslint .",
    "prepare": "husky",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "sync:keycloak": "npx --no-install tsx tools/sync-keycloak.ts",
    "generate:preview": "npx --no-install tsx tools/generate-preview.ts"
  },
  "dependencies": {
    "@codemirror/autocomplete": "6.20.1",
    "@codemirror/lang-css": "6.3.1",
    "@mdi/js": "^7.4.47",
    "@mdi/react": "^1.6.1",
    "@patternfly-v5/patternfly": "npm:@patternfly/patternfly@^5.4.2",
    "@patternfly/react-core": "6.4.1",
    "@patternfly/react-icons": "6.4.0",
    "@patternfly/react-styles": "6.4.0",
    "@uiw/react-codemirror": "4.25.9",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "css-tree": "^3.2.1",
    "fflate": "0.8.2",
    "file-selector": "2.1.2",
    "immer": "^11.1.4",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@antfu/eslint-config": "7.7.3",
    "@eslint-react/eslint-plugin": "3.0.0",
    "@playwright/test": "^1.58.2",
    "@rolldown/plugin-babel": "^0.2.2",
    "@types/css-tree": "^2.3.11",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "10.1.0",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "husky": "^9.1.7",
    "prettier": "3.8.1",
    "tsup": "^8.5.1",
    "tsx": "4.21.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.1",
    "vite-plugin-static-copy": "^4.0.0",
    "vitest": "^4.1.0"
  }
}
